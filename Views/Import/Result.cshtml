@model CrashReport.Services.ImportResult
@{
    ViewData["Title"] = "Import Result";
}

<div style="max-width:700px;">

    <!-- Summary card -->
    <div style="background:#fff;border-radius:10px;border:1px solid #c8e6c9;
                box-shadow:0 2px 8px rgba(0,0,0,.06);padding:28px 32px;margin-bottom:20px;">

        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
            @if (Model.Success)
            {
                <div style="width:40px;height:40px;border-radius:50%;background:#2e7d32;
                                display:flex;align-items:center;justify-content:center;
                                color:#fff;font-size:1.2rem;">
                    ✓
                </div>
                <div>
                    <div style="font-weight:700;color:#1b5e20;font-size:1rem;">Import Successful</div>
                    <div style="font-size:.82rem;color:#666;">@Model.SheetName — @Model.ReportPeriod</div>
                </div>
            }
            else
            {
                <div style="width:40px;height:40px;border-radius:50%;background:#b71c1c;
                                display:flex;align-items:center;justify-content:center;
                                color:#fff;font-size:1.2rem;">
                    ✗
                </div>
                <div>
                    <div style="font-weight:700;color:#b71c1c;font-size:1rem;">Import Failed</div>
                    <div style="font-size:.82rem;color:#666;">@Model.SheetName</div>
                </div>
            }
        </div>

        <!-- Stat tiles -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;">
            <div style="background:#e8f5e9;border-radius:8px;padding:14px 16px;text-align:center;">
                <div style="font-size:1.8rem;font-weight:800;color:#2e7d32;">@Model.ImportedCount</div>
                <div style="font-size:.75rem;color:#555;margin-top:3px;">Imported</div>
            </div>
            <div style="background:#fff3e0;border-radius:8px;padding:14px 16px;text-align:center;">
                <div style="font-size:1.8rem;font-weight:800;color:#e65100;">@Model.DuplicateCount</div>
                <div style="font-size:.75rem;color:#555;margin-top:3px;">Duplicates Skipped</div>
            </div>
            <div style="background:#fce4ec;border-radius:8px;padding:14px 16px;text-align:center;">
                <div style="font-size:1.8rem;font-weight:800;color:#b71c1c;">@Model.SkippedCount</div>
                <div style="font-size:.75rem;color:#555;margin-top:3px;">Rows Skipped</div>
            </div>
            <div style="background:#e8eaf6;border-radius:8px;padding:14px 16px;text-align:center;">
                <div style="font-size:1.8rem;font-weight:800;color:#283593;">@Model.Warnings.Count</div>
                <div style="font-size:.75rem;color:#555;margin-top:3px;">Warnings</div>
            </div>
        </div>

        <div style="display:flex;gap:10px;" id="resultActions"></div>
    </div>

    <!-- Errors -->
    @if (Model.Errors.Any())
    {
        <div style="background:#ffebee;border-radius:10px;border:1px solid #ef9a9a;
                        padding:18px 22px;margin-bottom:16px;">
            <div style="font-weight:700;color:#b71c1c;margin-bottom:10px;font-size:.85rem;">
                Errors
            </div>
            @foreach (var e in Model.Errors)
            {
                <div style="font-size:.82rem;color:#c62828;margin-bottom:4px;">✗ @e</div>
            }
        </div>
    }

    <!-- Warnings -->
    @if (Model.Warnings.Any())
    {
        <div style="background:#fff8e1;border-radius:10px;border:1px solid #ffe082;
                        padding:18px 22px;">
            <div style="font-weight:700;color:#e65100;margin-bottom:10px;font-size:.85rem;">
                Warnings (@Model.Warnings.Count)
            </div>
            <div style="max-height:250px;overflow-y:auto;">
                @foreach (var w in Model.Warnings)
                {
                    <div style="font-size:.8rem;color:#bf360c;margin-bottom:4px;">⚠ @w</div>
                }
            </div>
        </div>
    }

</div>

@section Scripts {
    <script>
        $(function () {
            var actions = document.getElementById("resultActions");
            $("<div>").appendTo(actions).dxButton({
                text: "View Crash Reports", type: "default", icon: "find",
                onClick: function () { window.location.href = "/Crashes"; }
            });
            $("<div>").appendTo(actions).dxButton({
                text: "Import Another", type: "normal", icon: "upload", stylingMode: "outlined",
                onClick: function () { window.location.href = "/Import"; }
            });
            $("<div>").appendTo(actions).dxButton({
                text: "Dashboard", type: "normal", icon: "home", stylingMode: "outlined",
                onClick: function () { window.location.href = "/"; }
            });
        });
    </script>
}
