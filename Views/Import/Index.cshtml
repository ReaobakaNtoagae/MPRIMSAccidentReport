@{
    ViewData["Title"] = "Import Excel Accident Report";
    var provinces = new[] {
        new { Code="EC",  Name="Eastern Cape"   },
        new { Code="FS",  Name="Free State"     },
        new { Code="GP",  Name="Gauteng"        },
        new { Code="KZN", Name="KwaZulu-Natal"  },
        new { Code="LP",  Name="Limpopo"        },
        new { Code="MP",  Name="Mpumalanga"     },
        new { Code="NC",  Name="Northern Cape"  },
        new { Code="NW",  Name="North West"     },
        new { Code="WC",  Name="Western Cape"   }
    };
}

<div style="max-width:620px;">

    @if (TempData["ImportError"] != null)
    {
        <div id="errMsg" data-msg="@TempData["ImportError"]"></div>
    }

    <div style="background:#fff;border-radius:10px;border:1px solid #c8e6c9;
                box-shadow:0 2px 8px rgba(0,0,0,.06);padding:28px 32px;margin-bottom:20px;">

        <div style="font-size:.78rem;text-transform:uppercase;letter-spacing:.7px;
                    color:#2e7d32;font-weight:700;margin-bottom:18px;">
            Upload Accident Report Workbook
        </div>

        <form method="post"
              asp-controller="Import"
              asp-action="Upload"
              enctype="multipart/form-data"
              id="uploadForm">
            @Html.AntiForgeryToken()

            
            <div style="margin-bottom:16px;">
                <div style="font-size:.75rem;color:#555;margin-bottom:6px;font-weight:600;">
                    Province (applied to all imported records)
                </div>
                <div id="provinceSelect"></div>
                <input type="hidden" id="provinceHidden" name="province" value="MP" />
            </div>

            <div style="margin-bottom:20px;">
                <div style="font-size:.75rem;color:#555;margin-bottom:6px;font-weight:600;">
                    Excel File (.xlsx)
                </div>
                <label for="fileInput" id="fileDropZone"
                       style="display:flex;flex-direction:column;align-items:center;justify-content:center;
                              gap:8px;padding:28px 20px;border:2px dashed #a5d6a7;border-radius:8px;
                              background:#f9fdf9;cursor:pointer;transition:all .2s;">
                    <span style="font-size:1.6rem;">📂</span>
                    <span style="font-size:.84rem;color:#555;">
                        Click to select or drop an Excel workbook here
                    </span>
                    <span id="fileNameDisplay"
                          style="font-size:.78rem;color:#888;font-style:italic;">
                        No file selected
                    </span>
                </label>
                <input type="file"
                       id="fileInput"
                       name="file"
                       accept=".xlsx,.xls"
                       style="display:none;"
                       required />
            </div>

          
            <button type="submit"
                    id="submitBtn"
                    disabled
                    style="width:100%;padding:11px 0;background:#2e7d32;color:#fff;
                           border:none;border-radius:7px;font-size:.88rem;font-weight:600;
                           cursor:pointer;transition:background .2s;letter-spacing:.2px;">
                Import Accidents
            </button>
        </form>
    </div>

    <!-- Format guide -->
    <div style="background:#f1f8f1;border-radius:10px;border:1px solid #c8e6c9;
                padding:20px 24px;">
        <div style="font-size:.78rem;text-transform:uppercase;letter-spacing:.7px;
                    color:#2e7d32;font-weight:700;margin-bottom:12px;">
            Expected Workbook Format
        </div>
        <div style="font-size:.82rem;color:#444;line-height:1.7;">
            <div style="display:grid;grid-template-columns:120px 1fr;gap:4px 16px;">
                <div style="color:#888;font-size:.76rem;">Row 1</div>
                <div>Report title &amp; period (e.g. ACCIDENT REPORT: 01 – 28 FEBRUARY 2025)</div>
                <div style="color:#888;font-size:.76rem;">Row 3</div>
                <div>District name (e.g. EHLANZENI)</div>
                <div style="color:#888;font-size:.76rem;">Row 6</div>
                <div>Column headers: SAPS | AR NO | CAS | DATE | DAY | TIME | ROUTE | LOCATION | TYPE | …</div>
                <div style="color:#888;font-size:.76rem;">Row 7+</div>
                <div>One accident per row</div>
                <div style="color:#888;font-size:.76rem;">Cols J–W</div>
                <div>Fatal / Serious / Slight injury counts (D=Driver, P=Passenger, PD=Pedestrian, C=Cyclist)</div>
                <div style="color:#888;font-size:.76rem;">Col X</div>
                <div>Vehicles involved (e.g. SED / TAXI)</div>
                <div style="color:#888;font-size:.76rem;">Stop row</div>
                <div>Row starting with TOTAL or GRAND TOTAL — import stops here</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {

            // ── Error toast ───────────────────────────────────────────
            var errMsg = $("#errMsg").data("msg");
            if (errMsg) DevExpress.ui.notify(errMsg, "error", 5000);

            // ── Province selector ─────────────────────────────────────
            var provinceItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                            provinces.Select(p => new { text = $"{p.Code} — {p.Name}", value = p.Code })
                    ));

        $("#provinceSelect").dxSelectBox({
            items:       provinceItems,
            displayExpr: "text",
            valueExpr:   "value",
            value:       "MP",
            onValueChanged: function (e) {
                $("#provinceHidden").val(e.value);
            }
        });

            // ── File input ────────────────────────────────────────────
            var fileInput  = document.getElementById("fileInput");
            var submitBtn  = document.getElementById("submitBtn");
            var dropZone   = document.getElementById("fileDropZone");
            var nameDisplay= document.getElementById("fileNameDisplay");

            function onFileSelected(file) {
                if (!file) return;
                var ext = file.name.split('.').pop().toLowerCase();
                if (ext !== "xlsx" && ext !== "xls") {
                    DevExpress.ui.notify("Only .xlsx and .xls files are supported.", "error", 4000);
                    fileInput.value = "";
                    nameDisplay.textContent = "No file selected";
                    submitBtn.disabled = true;
                    return;
                }
                if (file.size > 10 * 1024 * 1024) {
                    DevExpress.ui.notify("File too large. Maximum 10 MB.", "error", 4000);
                    fileInput.value = "";
                    nameDisplay.textContent = "No file selected";
                    submitBtn.disabled = true;
                    return;
                }
                nameDisplay.textContent = file.name;
                nameDisplay.style.color = "#2e7d32";
                nameDisplay.style.fontStyle = "normal";
                dropZone.style.borderColor = "#2e7d32";
                dropZone.style.background  = "#f1f8f1";
                submitBtn.disabled = false;
            }

            // Click to select
            fileInput.addEventListener("change", function () {
                onFileSelected(this.files[0]);
            });

            // Drag and drop
            dropZone.addEventListener("dragover", function (e) {
                e.preventDefault();
                dropZone.style.borderColor  = "#2e7d32";
                dropZone.style.background   = "#e8f5e9";
            });

            dropZone.addEventListener("dragleave", function () {
                dropZone.style.borderColor  = "#a5d6a7";
                dropZone.style.background   = "#f9fdf9";
            });

            dropZone.addEventListener("drop", function (e) {
                e.preventDefault();
                dropZone.style.borderColor  = "#a5d6a7";
                dropZone.style.background   = "#f9fdf9";
                var file = e.dataTransfer.files[0];
                if (file) {
                    // Assign to the native input so it submits with the form
                    var dt = new DataTransfer();
                    dt.items.add(file);
                    fileInput.files = dt.files;
                    onFileSelected(file);
                }
            });

            // ── Submit feedback ───────────────────────────────────────
            document.getElementById("uploadForm").addEventListener("submit", function () {
                submitBtn.disabled    = true;
                submitBtn.textContent = "Importing — please wait...";
                submitBtn.style.background = "#4a8554";
                DevExpress.ui.notify("Importing workbook — this may take a moment...", "info", 10000);
            });

            // ── Submit button hover ───────────────────────────────────
            submitBtn.addEventListener("mouseover", function () {
                if (!this.disabled) this.style.background = "#256328";
            });
            submitBtn.addEventListener("mouseout", function () {
                if (!this.disabled) this.style.background = "#2e7d32";
            });
        });
    </script>
}
