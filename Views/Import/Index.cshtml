@{
    ViewData["Title"] = "Import Excel Accident Report";
    var provinces = new[] {
        new { Code="EC",  Name="Eastern Cape"   },
        new { Code="FS",  Name="Free State"     },
        new { Code="GP",  Name="Gauteng"        },
        new { Code="KZN", Name="KwaZulu-Natal"  },
        new { Code="LP",  Name="Limpopo"        },
        new { Code="MP",  Name="Mpumalanga"     },
        new { Code="NC",  Name="Northern Cape"  },
        new { Code="NW",  Name="North West"     },
        new { Code="WC",  Name="Western Cape"   }
    };
}

<style>
    .imp-wrap {
        max-width: 560px;
    }

    .imp-card {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #c8e6c9;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        overflow: hidden;
        margin-bottom: 14px;
    }

    .imp-card-head {
        padding: 11px 20px;
        border-bottom: 2px solid #e8f5e9;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: #2e7d32;
        font-weight: 700;
    }

    .imp-card-body {
        padding: 20px;
    }

    .imp-field {
        margin-bottom: 16px;
    }

        .imp-field:last-child {
            margin-bottom: 0;
        }

    .imp-field-label {
        font-size: .72rem;
        font-weight: 600;
        color: #444;
        display: block;
        margin-bottom: 5px;
    }

    /* Guide */
    .imp-guide-row {
        display: grid;
        grid-template-columns: 80px 1fr;
        gap: 4px 14px;
        padding: 7px 0;
        border-bottom: 1px solid #e8f5e9;
        align-items: start;
    }

        .imp-guide-row:last-child {
            border-bottom: none;
        }

    .imp-guide-key {
        font-size: .70rem;
        color: #888;
        font-weight: 600;
        padding-top: 2px;
    }

    .imp-guide-val {
        font-size: .79rem;
        color: #333;
        line-height: 1.5;
    }
</style>

<div class="imp-wrap">

    @if (TempData["ImportError"] != null)
    {
        <div id="errMsg" data-msg="@TempData["ImportError"]"></div>
    }

    <div class="imp-card">
        <div class="imp-card-head">Upload Accident Report Workbook</div>
        <div class="imp-card-body">

            <form method="post"
                  asp-controller="Import"
                  asp-action="Upload"
                  enctype="multipart/form-data"
                  id="uploadForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="provinceHidden" name="province" value="MP" />

                <div class="imp-field">
                    <label class="imp-field-label">Province — applied to all imported records</label>
                    <div id="provinceSelect"></div>
                </div>

                <div class="imp-field">
                    <label class="imp-field-label">Excel File (.xlsx / .xls — maximum 10 MB)</label>
                    <div id="fileUploader"></div>
                </div>

                <div class="imp-field">
                    <div id="btnSubmit"></div>
                </div>

            </form>
        </div>
    </div>

    <div class="imp-card">
        <div class="imp-card-head">Expected Workbook Format</div>
        <div class="imp-card-body">
            <div class="imp-guide-row">
                <div class="imp-guide-key">Row 1</div>
                <div class="imp-guide-val">Report title and period (e.g. ACCIDENT REPORT: 01 – 28 FEBRUARY 2025)</div>
            </div>
            <div class="imp-guide-row">
                <div class="imp-guide-key">Row 3</div>
                <div class="imp-guide-val">District name (e.g. EHLANZENI)</div>
            </div>
            <div class="imp-guide-row">
                <div class="imp-guide-key">Row 6</div>
                <div class="imp-guide-val">Headers: SAPS | AR NO | CAS | DATE | DAY | TIME | ROUTE | LOCATION | TYPE | …</div>
            </div>
            <div class="imp-guide-row">
                <div class="imp-guide-key">Row 7+</div>
                <div class="imp-guide-val">One accident per row</div>
            </div>
            <div class="imp-guide-row">
                <div class="imp-guide-key">Cols J – W</div>
                <div class="imp-guide-val">Injury counts (Fatal / Serious / Slight) by role — Driver, Passenger, Pedestrian, Cyclist</div>
            </div>
            <div class="imp-guide-row">
                <div class="imp-guide-key">Col X</div>
                <div class="imp-guide-val">Vehicles involved (e.g. SED / TAXI)</div>
            </div>
            <div class="imp-guide-row">
                <div class="imp-guide-key">Stop row</div>
                <div class="imp-guide-val">Row beginning with TOTAL or GRAND TOTAL — import stops here</div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        $(function () {

            // ── Error from previous attempt ───────────────────────────
            var errMsg = $("#errMsg").data("msg");
            if (errMsg) DevExpress.ui.notify(errMsg, "error", 5000);

            // ── Province select ───────────────────────────────────────
            var provinceItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                            provinces.Select(p => new { text = $"{p.Code} — {p.Name}", value = p.Code })
                    ));

        $("#provinceSelect").dxSelectBox({
            items:          provinceItems,
            displayExpr:    "text",
            valueExpr:      "value",
            value:          "MP",
            width:          "100%",
            onValueChanged: function (e) {
                $("#provinceHidden").val(e.value);
            }
        });

            // ── File uploader ─────────────────────────────────────────
            // uploadMode:"useForm" means the widget does NOT upload
            // automatically — it just holds the file for the form POST.
            // The name "file" matches ImportController.Upload(IFormFile file).
            var fileUploaderInst = $("#fileUploader").dxFileUploader({
                name:             "file",
                uploadMode:       "useForm",
                accept:           ".xlsx,.xls",
                multiple:         false,
                selectButtonText: "Select Excel file",
                labelText:        "or drop it here",
                allowedFileExtensions: [".xlsx", ".xls"],
                maxFileSize:      10 * 1024 * 1024,   // 10 MB
                invalidFileExtensionMessage: "Only .xlsx and .xls files are supported.",
                invalidMaxFileSizeMessage:   "File size must not exceed 10 MB.",
                onValueChanged: function (e) {
                    var hasFile = e.value && e.value.length > 0;
                    submitBtnInst.option("disabled", !hasFile);
                }
            }).dxFileUploader("instance");

            // ── Submit button ─────────────────────────────────────────
            var submitBtnInst = $("#btnSubmit").dxButton({
                text:          "Import Records",
                type:          "default",
                icon:          "upload",
                width:         "100%",
                disabled:      true,
                onClick: function () {
                    var files = fileUploaderInst.option("value");
                    if (!files || files.length === 0) {
                        DevExpress.ui.notify("Please select an Excel file first.", "warning", 3000);
                        return;
                    }
                    submitBtnInst.option("text",     "Importing — please wait…");
                    submitBtnInst.option("disabled", true);
                    DevExpress.ui.notify("Importing workbook. This may take a moment.", "info", 10000);
                    document.getElementById("uploadForm").submit();
                }
            }).dxButton("instance");

        });
    </script>
}
