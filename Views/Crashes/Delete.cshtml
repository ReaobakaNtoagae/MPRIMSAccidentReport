@model CrashReport.Models.Crash
@{
    ViewData["Title"] = "Delete Crash Report";
}

<style>
    .delete-warning {
        background: #ffebee;
        border: 1px solid #ef9a9a;
        border-radius: 8px;
        padding: 14px 18px;
        margin-bottom: 16px;
        color: #b71c1c;
        font-weight: 600;
        font-size: .88rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .delete-warning::before {
            content: "⚠";
            font-size: 1.2rem;
        }

    .custom-dialog-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

        .custom-dialog-overlay.show {
            opacity: 1;
        }

    .custom-dialog {
        background: white;
        border-radius: 12px;
        width: 420px;
        max-width: 90%;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        overflow: hidden;
        transform: scale(0.95);
        transition: transform 0.2s ease;
    }

    .custom-dialog-overlay.show .custom-dialog {
        transform: scale(1);
    }

    .custom-dialog-header {
        background: #dc3545;
        color: white;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .custom-dialog-header .icon {
            font-size: 1.5rem;
        }

        .custom-dialog-header h3 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 600;
        }

    .custom-dialog-body {
        padding: 20px;
    }

        .custom-dialog-body p {
            margin: 0 0 10px 0;
            color: #333;
            line-height: 1.5;
        }

        .custom-dialog-body .cr-number {
            font-weight: 700;
            color: #dc3545;
            background: #ffebee;
            padding: 2px 8px;
            border-radius: 4px;
            font-family: monospace;
        }

    .custom-dialog-footer {
        padding: 16px 20px;
        background: #f8f9fa;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        border-top: 1px solid #e9ecef;
    }

    .warning-text {
        color: #dc3545;
        font-weight: 600;
        margin-top: 10px !important;
    }

    .confirm-input {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        margin-top: 8px;
        font-family: monospace;
        font-size: 1rem;
        text-align: center;
        letter-spacing: 2px;
    }

        .confirm-input:focus {
            outline: none;
            border-color: #dc3545;
            box-shadow: 0 0 0 2px rgba(220, 53, 69, 0.2);
        }
</style>

<div id="deleteContainer" style="max-width:560px;"></div>

<form method="post" id="deleteForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.CrashId" />
</form>

@section Scripts {
    <script>
        $(document).ready(function() {
            var container = $("#deleteContainer");

        
            $("<div>")
                .addClass("delete-warning")
                .html("This will permanently delete this crash report and ALL linked records. This action cannot be undone.")
                .appendTo(container);

           
            $("<div>").appendTo(container).dxForm({
                readOnly: true,
                colCount: 2,
                formData: {
                    CrNo: "@Model.CrNo",
                    CasNo: "@Model.CasNo",
                    CrashDate: "@Model.CrashDate.ToString("dd MMM yyyy")",
                    Location: "@(Model.CrashLocations?.FirstOrDefault()?.StreetRoadName ?? Model.CrashLocations?.FirstOrDefault()?.CityTown ?? "—")"
                },
                items: [
                    { dataField: "CrNo", label: { text: "CR No." } },
                    { dataField: "CasNo", label: { text: "CAS No." } },
                    { dataField: "CrashDate", label: { text: "Date" } },
                    { dataField: "Location", label: { text: "Location" } }
                ]
            });

       
            var btnRow = $("<div>").css({ display: "flex", gap: "10px", marginTop: "20px" }).appendTo(container);

            
            $("<div>").appendTo(btnRow).dxButton({
                text: "Delete Report",
                type: "danger",
                icon: "trash",
                stylingMode: "contained",
                onClick: function() {
                    showCustomDialog();
                }
            });

        
            $("<div>").appendTo(btnRow).dxButton({
                text: "Cancel",
                type: "normal",
                stylingMode: "outlined",
                icon: "close",
                onClick: function() {
                    window.location.href = "/Crashes/Details/@Model.CrashId";
                }
            });

          
            function showCustomDialog() {
                var crNo = "@Model.CrNo";

                var $overlay = $('<div class="custom-dialog-overlay"></div>');

                var dialogHtml =
                    '<div class="custom-dialog">' +
                        '<div class="custom-dialog-header">' +
                            '<span class="icon">🗑️</span>' +
                            '<h3>Delete Crash Report</h3>' +
                        '</div>' +
                        '<div class="custom-dialog-body">' +
                            '<p>Are you sure you want to delete <strong>crash report <span class="cr-number">' + crNo + '</span></strong>?</p>' +
                            '<p>This will permanently remove this report and all associated data.</p>' +
                            '<p class="warning-text">This action cannot be undone!</p>' +
                            '<p style="margin-top: 12px; font-size: 0.85rem;">Type <strong style="color:#dc3545;">DELETE</strong> to confirm:</p>' +
                            '<input type="text" id="confirmInput" class="confirm-input" placeholder="DELETE" autocomplete="off">' +
                        '</div>' +
                        '<div class="custom-dialog-footer">' +
                            '<button id="confirmDeleteBtn" class="dx-button-danger" style="background: #dc3545; color: white; border: none; padding: 8px 20px; border-radius: 4px; cursor: pointer; font-weight: 600;">Delete</button>' +
                            '<button id="cancelDeleteBtn" style="background: #f8f9fa; color: #333; border: 1px solid #ddd; padding: 8px 20px; border-radius: 4px; cursor: pointer;">Cancel</button>' +
                        '</div>' +
                    '</div>';

                $overlay.html(dialogHtml);
                $('body').append($overlay);

                
                setTimeout(function() {
                    $overlay.addClass('show');
                }, 10);

               
                setTimeout(function() {
                    $('#confirmInput').focus();
                }, 100);

               
                $('#confirmDeleteBtn').on('click', function() {
                    var confirmText = $('#confirmInput').val().trim();
                    if (confirmText === 'DELETE') {
                        $overlay.remove();
                        document.getElementById("deleteForm").submit();
                    } else {
                        $('#confirmInput').css({
                            borderColor: '#dc3545',
                            backgroundColor: '#ffebee'
                        }).val('');
                        setTimeout(function() {
                            $('#confirmInput').css({
                                borderColor: '#ddd',
                                backgroundColor: ''
                            });
                        }, 500);

                        DevExpress.ui.notify("Please type DELETE to confirm deletion.", "error", 2000);
                    }
                });

      
                $('#cancelDeleteBtn').on('click', function() {
                    $overlay.removeClass('show');
                    setTimeout(function() {
                        $overlay.remove();
                    }, 200);
                });


                $('#confirmInput').on('keypress', function(e) {
                    if (e.which === 13) {
                        $('#confirmDeleteBtn').click();
                    }
                });

                $(document).on('keydown', function(e) {
                    if (e.key === 'Escape' && $overlay.length) {
                        $('#cancelDeleteBtn').click();
                    }
                });

            
                $overlay.on('click', function(e) {
                    if ($(e.target).hasClass('custom-dialog-overlay')) {
                        $overlay.removeClass('show');
                        setTimeout(function() {
                            $overlay.remove();
                        }, 200);
                    }
                });
            }
        });
    </script>
}