@model CrashReport.Models.Crash
@{
    ViewData["Title"] = "Delete Crash Report";
}

<div id="deleteContainer" style="max-width:560px;"></div>

<form method="post" id="deleteForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.CrashId" />
</form>

@section Scripts {
    <script>
        var container = $("#deleteContainer");

        // Warning notice
        $("<div>").css({
            background: "#ffebee", border: "1px solid #ef9a9a",
            borderRadius: "8px", padding: "14px 18px", marginBottom: "16px",
            color: "#b71c1c", fontWeight: "600", fontSize: ".88rem"
        }).html("&#9888;&nbsp; This will permanently delete this crash report and all linked records (vehicles, persons, witnesses, factors).").appendTo(container);

        // Read-only summary
        $("<div>").appendTo(container).dxForm({
            readOnly: true,
            colCount: 2,
            formData: {
                CrNo:      "@Model.CrNo",
                CasNo:     "@Model.CasNo",
                CrashDate: "@Model.CrashDate.ToString("dd MMM yyyy")",
                Location:  "@(Model.CrashLocations.FirstOrDefault()?.StreetRoadName ?? Model.CrashLocations.FirstOrDefault()?.CityTown ?? "—")"
            },
            items: [
                { dataField: "CrNo",      label: { text: "CR No." } },
                { dataField: "CasNo",     label: { text: "CAS No." } },
                { dataField: "CrashDate", label: { text: "Date" } },
                { dataField: "Location",  label: { text: "Location" } }
            ]
        });

        // Buttons
        var btnRow = $("<div>").css({ display: "flex", gap: "10px", marginTop: "16px" }).appendTo(container);

        $("<div>").appendTo(btnRow).dxButton({
            text: "Yes, Delete Permanently", type: "danger", icon: "trash",
            onClick: function () {
                DevExpress.ui.dialog.confirm(
                    "Are you absolutely sure you want to delete this record?",
                    "Confirm Delete"
                ).then(function (confirmed) {
                    if (confirmed) document.getElementById("deleteForm").submit();
                });
            }
        });
        $("<div>").appendTo(btnRow).dxButton({
            text: "Cancel", type: "normal", stylingMode: "outlined",
            onClick: function () { window.location.href = "/Crashes"; }
        });
    </script>
}
