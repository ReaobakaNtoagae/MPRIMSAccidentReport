@{
    ViewData["Title"] = "Monthly Memo Report";
}

<style>
    .memo-layout {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 20px;
        align-items: start;
    }

    /* ── Shared card ── */
    .memo-card {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #c8e6c9;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        margin-bottom: 14px;
        overflow: hidden;
    }

    .memo-card-head {
        padding: 11px 18px;
        border-bottom: 2px solid #e8f5e9;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: #2e7d32;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        user-select: none;
    }

    .memo-card-head-badge {
        font-size: .68rem;
        text-transform: none;
        letter-spacing: 0;
        color: #999;
        font-weight: 400;
    }

    .memo-card-body {
        padding: 18px;
    }

    .memo-field {
        margin-bottom: 12px;
    }

        .memo-field:last-child {
            margin-bottom: 0;
        }

        .memo-field label {
            display: block;
            font-size: .71rem;
            font-weight: 600;
            color: #444;
            margin-bottom: 4px;
        }

    .memo-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .memo-divider {
        border: none;
        border-top: 1px solid #e8f5e9;
        margin: 14px 0;
    }

    /* ── Preview panel ── */
    .pv-empty {
        padding: 60px 20px;
        text-align: center;
        color: #bbb;
        font-size: .85rem;
    }

        .pv-empty i {
            font-size: 2rem;
            display: block;
            margin-bottom: 10px;
        }

    .pv-section {
        margin-bottom: 24px;
    }

    .pv-section-title {
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .9px;
        color: #999;
        font-weight: 700;
        margin-bottom: 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid #f0f0f0;
    }

    /* Stat tiles — minimal */
    .pv-tiles {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
        margin-bottom: 4px;
    }

    .pv-tile {
        border: 1px solid #ebebeb;
        border-radius: 7px;
        padding: 10px 10px 8px;
        text-align: center;
    }

    .pv-tile-label {
        font-size: .65rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #aaa;
        font-weight: 600;
        margin-bottom: 6px;
    }

    .pv-tile-prev {
        font-size: .72rem;
        color: #ccc;
        margin-bottom: 2px;
    }

    .pv-tile-curr {
        font-size: 1.4rem;
        font-weight: 500;
        color: #222;
        line-height: 1;
    }

    .pv-tile-var {
        font-size: .68rem;
        font-weight: 700;
        margin-top: 4px;
        letter-spacing: .2px;
    }

    .pv-up {
        color: #c0392b;
    }

    .pv-down {
        color: #27ae60;
    }

    .pv-flat {
        color: #aaa;
    }

    /* Minimal tables */
    .pv-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .78rem;
    }

        .pv-table thead tr {
            border-bottom: 1px solid #e0e0e0;
        }

        .pv-table th {
            font-size: .67rem;
            text-transform: uppercase;
            letter-spacing: .5px;
            font-weight: 600;
            color: #999;
            padding: 5px 10px 7px;
            text-align: right;
        }

            .pv-table th:first-child {
                text-align: left;
            }

        .pv-table td {
            padding: 6px 10px;
            text-align: right;
            color: #444;
            border-bottom: 1px solid #f5f5f5;
        }

            .pv-table td:first-child {
                text-align: left;
                color: #222;
                font-weight: 500;
            }

            .pv-table td.pv-prev {
                color: #ccc;
            }

            .pv-table td.pv-var {
                font-weight: 700;
            }

    .pv-summary {
        background: #fafafa;
        border: 1px solid #f0f0f0;
        border-radius: 7px;
        padding: 14px 16px;
    }

    .pv-summary-row {
        display: flex;
        align-items: baseline;
        gap: 6px;
        font-size: .81rem;
        color: #444;
        padding: 3px 0;
    }

    .pv-summary-key {
        color: #aaa;
        min-width: 80px;
        font-size: .73rem;
    }

    .pv-summary-val {
        font-weight: 600;
        color: #222;
    }

    /* Loading overlay */
    .memo-loading {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.32);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 14px;
    }

        .memo-loading.show {
            display: flex;
        }

    .memo-spinner {
        width: 44px;
        height: 44px;
        border: 4px solid rgba(255,255,255,.25);
        border-top-color: #fff;
        border-radius: 50%;
        animation: memo-spin .75s linear infinite;
    }

    .memo-loading-text {
        color: #fff;
        font-size: .9rem;
        font-weight: 500;
    }

    @@keyframes memo-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="memo-loading" id="loadingOverlay">
    <div class="memo-spinner"></div>
    <div class="memo-loading-text" id="loadingText">Loading…</div>
</div>

<div class="memo-layout">

    <!-- ── LEFT: Controls ─────────────────────────────────────── -->
    <div>

        <!-- Period -->
        <div class="memo-card">
            <div class="memo-card-head" style="cursor:default;">Report Period</div>
            <div class="memo-card-body">
                <div class="memo-field">
                    <label>From</label>
                    <div id="dateFromBox"></div>
                </div>
                <div class="memo-field">
                    <label>To</label>
                    <div id="dateToBox"></div>
                </div>

                <hr class="memo-divider" />

                <div style="font-size:.68rem;text-transform:uppercase;letter-spacing:.6px;
                            color:#aaa;font-weight:700;margin-bottom:10px;">
                    Comparison Period
                </div>
                <div class="memo-field">
                    <label>Compare From</label>
                    <div id="compFromBox"></div>
                </div>
                <div class="memo-field" style="margin-bottom:14px;">
                    <label>Compare To</label>
                    <div id="compToBox"></div>
                </div>
                <div id="btnAutoFill"></div>
            </div>
        </div>

        <!-- Memo Header -->
        <div class="memo-card">
            <div class="memo-card-head" id="hdrToggle">
                <span>Memo Header</span>
                <i class="ti ti-chevron-down" id="hdrChevron" style="font-size:13px;transition:transform .2s;" aria-hidden="true"></i>
            </div>
            <div class="memo-card-body" id="hdrBody">
                <div class="memo-two-col" style="margin-bottom:12px;">
                    <div class="memo-field" style="margin-bottom:0;">
                        <label>Report Date</label>
                        <div id="reportDateBox"></div>
                    </div>
                    <div class="memo-field" style="margin-bottom:0;">
                        <label>Reference No.</label>
                        <div id="refNumBox"></div>
                    </div>
                </div>
                <div class="memo-field"><label>To — Name</label><div id="toNameBox"></div></div>
                <div class="memo-field"><label>To — Title</label><div id="toTitleBox"></div></div>
                <div class="memo-field"><label>From — Name</label><div id="fromNameBox"></div></div>
                <div class="memo-field"><label>From — Title</label><div id="fromTitleBox"></div></div>
                <div class="memo-two-col">
                    <div class="memo-field" style="margin-bottom:0;">
                        <label>Enquiry Name</label>
                        <div id="enqNameBox"></div>
                    </div>
                    <div class="memo-field" style="margin-bottom:0;">
                        <label>Enquiry Tel</label>
                        <div id="enqTelBox"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="memo-card">
            <div class="memo-card-body" style="display:flex;flex-direction:column;gap:8px;">
                <div id="btnPreview"></div>
                <div id="btnDownload"></div>
            </div>
        </div>

    </div>

    <!-- ── RIGHT: Preview ─────────────────────────────────────── -->
    <div class="memo-card">
        <div class="memo-card-head" style="cursor:default;">
            <span>Data Preview</span>
            <span id="previewPeriodLabel" class="memo-card-head-badge"></span>
        </div>
        <div id="previewArea" style="padding:20px;">
            <div class="pv-empty">
                <i class="ti ti-chart-bar" aria-hidden="true"></i>
                Select a period and click Preview to see the data.
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        $(function () {

            var previewData = null;

            // ── Defaults ───────────────────────────────────────────────
            var today        = new Date();
            var firstOfMonth = new Date(today.getFullYear(), today.getMonth(),     1);
            var lastOfMonth  = new Date(today.getFullYear(), today.getMonth() + 1, 0);
            var compFrom     = new Date(firstOfMonth); compFrom.setFullYear(compFrom.getFullYear() - 1);
            var compTo       = new Date(lastOfMonth);  compTo.setFullYear(compTo.getFullYear() - 1);

            // ── Date pickers ───────────────────────────────────────────
            var dateFromInst = $("#dateFromBox").dxDateBox({
                type: "date", displayFormat: "dd/MM/yyyy", value: firstOfMonth,
                max: new Date(),
                onValueChanged: function (e) {
                    var d = new Date(e.value); d.setFullYear(d.getFullYear() - 1);
                    compFromInst.option("value", d);
                }
            }).dxDateBox("instance");

            var dateToInst = $("#dateToBox").dxDateBox({
                type: "date", displayFormat: "dd/MM/yyyy", value: lastOfMonth,
                max: new Date(),
                onValueChanged: function (e) {
                    var d = new Date(e.value); d.setFullYear(d.getFullYear() - 1);
                    compToInst.option("value", d);
                }
            }).dxDateBox("instance");

            var compFromInst = $("#compFromBox").dxDateBox({
                type: "date", displayFormat: "dd/MM/yyyy", value: compFrom
            }).dxDateBox("instance");

            var compToInst = $("#compToBox").dxDateBox({
                type: "date", displayFormat: "dd/MM/yyyy", value: compTo
            }).dxDateBox("instance");

            $("#btnAutoFill").dxButton({
                text: "Auto-fill prior year", type: "normal", stylingMode: "outlined",
                icon: "refresh", width: "100%",
                onClick: function () {
                    var f = new Date(dateFromInst.option("value")),
                        t = new Date(dateToInst.option("value"));
                    f.setFullYear(f.getFullYear() - 1);
                    t.setFullYear(t.getFullYear() - 1);
                    compFromInst.option("value", f);
                    compToInst.option("value",   t);
                    DevExpress.ui.notify("Comparison period updated.", "success", 2000);
                }
            });

            // ── Memo header fields ────────────────────────────────────
            function tb(id, ph, val) {
                return $(id).dxTextBox({ placeholder: ph, value: val || "", showClearButton: true })
                            .dxTextBox("instance");
            }

            var reportDateInst = tb("#reportDateBox", "e.g. 03 MAY 2025",
                new Date().toLocaleDateString("en-ZA",{day:"2-digit",month:"long",year:"numeric"}).toUpperCase());
            var refNumInst   = tb("#refNumBox",    "e.g. 16/9/4",                   "16/9/4");
            var toNameInst   = tb("#toNameBox",    "MEC name",                      "MR P NGOMANE (MPL)");
            var toTitleInst  = tb("#toTitleBox",   "MEC title",                     "MEMBER OF THE EXECUTIVE COUNCIL");
            var fromNameInst = tb("#fromNameBox",  "HOD name",                      "MR W MTHOMBOTHI");
            var fromTitleInst= tb("#fromTitleBox", "HOD title",                     "HEAD OF DEPARTMENT");
            var enqNameInst  = tb("#enqNameBox",   "Enquiry name",                  "M C Mdhluli");
            var enqTelInst   = tb("#enqTelBox",    "Tel number",                    "082 802 6966");

            // ── Collapsible header section ────────────────────────────
            var hdrOpen = true;
            $("#hdrToggle").on("click", function () {
                hdrOpen = !hdrOpen;
                $("#hdrBody").slideToggle(180);
                $("#hdrChevron").css("transform", hdrOpen ? "" : "rotate(-90deg)");
            });

            // ── Build request ─────────────────────────────────────────
            function buildRequest() {
                function fmt(d) {
                    if (!d) return "";
                    var dt = new Date(d);
                    return dt.getFullYear() + "-" +
                           String(dt.getMonth() + 1).padStart(2, "0") + "-" +
                           String(dt.getDate()).padStart(2, "0");
                }
                return {
                    DateFrom:    fmt(dateFromInst.option("value")),
                    DateTo:      fmt(dateToInst.option("value")),
                    CompareFrom: fmt(compFromInst.option("value")),
                    CompareTo:   fmt(compToInst.option("value")),
                    ReportDate:  reportDateInst.option("value"),
                    RefNumber:   refNumInst.option("value"),
                    ToName:      toNameInst.option("value"),
                    ToTitle:     toTitleInst.option("value"),
                    FromName:    fromNameInst.option("value"),
                    FromTitle:   fromTitleInst.option("value"),
                    EnquiryName: enqNameInst.option("value"),
                    EnquiryTel:  enqTelInst.option("value")
                };
            }

            // ── Buttons ───────────────────────────────────────────────
            $("#btnPreview").dxButton({
                text: "Preview Data", type: "normal", icon: "find", width: "100%",
                onClick: runPreview
            });

            $("#btnDownload").dxButton({
                text: "Download Word Memo", type: "default", icon: "download", width: "100%",
                onClick: runDownload
            });

            function runPreview() {
                var req = buildRequest();
                if (!req.DateFrom || !req.DateTo) {
                    DevExpress.ui.notify("Select a report period.", "warning", 2500); return;
                }
                showLoading("Loading data…");
                $.ajax({
                    url: "/MemoReport/Preview", method: "POST",
                    contentType: "application/json", data: JSON.stringify(req),
                    success: function (vm) {
                        hideLoading();
                        previewData = vm;
                        renderPreview(vm);
                        DevExpress.ui.notify("Preview loaded for " + vm.MonthYear, "success", 2500);
                    },
                    error: function (xhr) {
                        hideLoading();
                        DevExpress.ui.notify(
                            (xhr.responseJSON && xhr.responseJSON.error) || "Preview failed.", "error", 3000);
                    }
                });
            }

            function runDownload() {
                var req = buildRequest();
                if (!req.DateFrom || !req.DateTo) {
                    DevExpress.ui.notify("Select a report period.", "warning", 2500); return;
                }
                showLoading("Generating Word memo — this may take ~30 seconds…");
                $.ajax({
                    url: "/MemoReport/Download", method: "POST",
                    contentType: "application/json", data: JSON.stringify(req),
                    xhrFields: { responseType: "blob" },
                    success: function (blob, status, xhr) {
                        hideLoading();
                        var cd   = xhr.getResponseHeader("Content-Disposition") || "";
                        var name = "Monthly_Memo.docx";
                        var m    = cd.match(/filename=([^;]+)/);
                        if (m) name = m[1].replace(/"/g, "");
                        var url = window.URL.createObjectURL(blob);
                        var a   = document.createElement("a");
                        a.href = url; a.download = name; a.click();
                        window.URL.revokeObjectURL(url);
                        DevExpress.ui.notify("Download started.", "success", 2500);
                    },
                    error: function (xhr) {
                        hideLoading();
                        DevExpress.ui.notify("Download failed.", "error", 4000);
                    }
                });
            }

            // ── Preview renderer ──────────────────────────────────────
            function renderPreview(vm) {
                var p  = vm.Provincial || {};
                var c  = p.Current     || {};
                var pr = p.Prior       || {};
                var cy = vm.CurrentYear, py = vm.PriorYear;

                $("#previewPeriodLabel").text(vm.PeriodFrom + " – " + vm.PeriodTo);

                var h = "";

                // ── Tiles
                h += '<div class="pv-section"><div class="pv-section-title">Provincial overview</div>';
                h += '<div class="pv-tiles">';
                [["Crashes", c.Crashes, pr.Crashes],
                 ["Fatalities", c.Fatalities, pr.Fatalities],
                 ["Serious", c.Serious, pr.Serious],
                 ["Slight", c.Slight, pr.Slight]].forEach(function (s) {
                    var vr  = variance(s[2], s[1]);
                    var cls = parseFloat(vr) > 0 ? "pv-up" : (parseFloat(vr) < 0 ? "pv-down" : "pv-flat");
                    var arrow = parseFloat(vr) > 0 ? "▲" : (parseFloat(vr) < 0 ? "▼" : "–");
                    h += '<div class="pv-tile">' +
                         '<div class="pv-tile-label">' + s[0] + '</div>' +
                         '<div class="pv-tile-prev">' + (s[2] || 0) + '</div>' +
                         '<div class="pv-tile-curr">' + (s[1] || 0) + '</div>' +
                         '<div class="pv-tile-var ' + cls + '">' + arrow + ' ' + vr + '</div>' +
                         '</div>';
                });
                h += '</div></div>';

                // ── Comparison table
                h += '<div class="pv-section"><div class="pv-section-title">Month comparison</div>';
                h += minTable([
                    ["Crashes",          pr.Crashes,    c.Crashes   ],
                    ["Fatalities",       pr.Fatalities, c.Fatalities],
                    ["Serious injuries", pr.Serious,    c.Serious   ],
                    ["Slight injuries",  pr.Slight,     c.Slight    ]
                ], py, cy) + '</div>';

                // ── 5-year history
                if (vm.FiveYearHistory && vm.FiveYearHistory.length > 0) {
                    h += '<div class="pv-section"><div class="pv-section-title">5-year history (' + vm.MonthName + ')</div>';
                    h += '<table class="pv-table"><thead><tr><th></th>';
                    vm.FiveYearHistory.forEach(function (yr) { h += '<th>' + yr.Year + '</th>'; });
                    h += '<th>Avg</th></tr></thead><tbody>';
                    ["Crashes", "Fatalities"].forEach(function (key) {
                        var vals = vm.FiveYearHistory.map(function (yr) { return yr[key] || 0; });
                        var avg  = (vals.reduce(function (a, b) { return a + b; }, 0) / vals.length).toFixed(1);
                        h += '<tr><td>' + key + '</td>';
                        vals.forEach(function (v) { h += '<td>' + v + '</td>'; });
                        h += '<td><strong>' + avg + '</strong></td></tr>';
                    });
                    h += '</tbody></table></div>';
                }

                // ── Victims
                h += '<div class="pv-section"><div class="pv-section-title">Fatal victims by category</div>';
                h += minTable([
                    ["Drivers",     pr.FatalDrivers,     c.FatalDrivers    ],
                    ["Passengers",  pr.FatalPassengers,  c.FatalPassengers ],
                    ["Pedestrians", pr.FatalPedestrians, c.FatalPedestrians],
                    ["Cyclists",    pr.FatalCyclists,    c.FatalCyclists   ]
                ], py, cy) + '</div>';

                // ── Serious injuries
                h += '<div class="pv-section"><div class="pv-section-title">Serious injuries by category</div>';
                h += minTable([
                    ["Drivers",     pr.SeriousDrivers,     c.SeriousDrivers    ],
                    ["Passengers",  pr.SeriousPassengers,  c.SeriousPassengers ],
                    ["Pedestrians", pr.SeriousPedestrians, c.SeriousPedestrians],
                    ["Cyclists",    pr.SeriousCyclists,    c.SeriousCyclists   ]
                ], py, cy) + '</div>';

                // ── Districts
                if (vm.Districts && vm.Districts.length > 0) {
                    h += '<div class="pv-section"><div class="pv-section-title">By district</div>';
                    h += '<table class="pv-table"><thead><tr><th></th>';
                    vm.Districts.forEach(function (d) {
                        h += '<th colspan="2">' + d.Name + '</th>';
                    });
                    h += '</tr><tr><th></th>';
                    vm.Districts.forEach(function () { h += '<th>' + py + '</th><th>' + cy + '</th>'; });
                    h += '</tr></thead><tbody>';
                    [["Crashes","Crashes"],["Fatal","Fatalities"],["Serious","Serious"],["Slight","Slight"]].forEach(function (m) {
                        h += '<tr><td>' + m[0] + '</td>';
                        vm.Districts.forEach(function (d) {
                            var pv = (d.Prior  && d.Prior[m[1]])   || 0;
                            var cv = (d.Current && d.Current[m[1]]) || 0;
                            h += '<td class="pv-prev">' + pv + '</td><td>' + cv + '</td>';
                        });
                        h += '</tr>';
                    });
                    h += '</tbody></table></div>';
                }

                // ── Routes
                if (vm.ProvincialRoutes && vm.ProvincialRoutes.length > 0) {
                    h += '<div class="pv-section"><div class="pv-section-title">Provincial routes</div>';
                    h += '<table class="pv-table"><thead><tr><th>Route</th>' +
                         '<th>Crashes ' + py + '</th><th>Crashes ' + cy + '</th>' +
                         '<th>Fatal ' + py + '</th><th>Fatal ' + cy + '</th></tr></thead><tbody>';
                    vm.ProvincialRoutes.forEach(function (r) {
                        h += '<tr><td>' + r.Route + '</td>' +
                             '<td class="pv-prev">' + (r.CrashesPrev||0) + '</td><td>' + (r.CrashesCurr||0) + '</td>' +
                             '<td class="pv-prev">' + (r.FatalPrev||0)   + '</td><td>' + (r.FatalCurr||0)   + '</td></tr>';
                    });
                    h += '</tbody></table></div>';
                }

                // ── Crash types
                if (vm.CrashTypes && vm.CrashTypes.length > 0) {
                    h += '<div class="pv-section"><div class="pv-section-title">Crash types</div>';
                    h += '<table class="pv-table"><thead><tr><th>Type</th>' +
                         '<th>Crashes ' + py + '</th><th>Crashes ' + cy + '</th>' +
                         '<th>Fatal ' + py + '</th><th>Fatal ' + cy + '</th></tr></thead><tbody>';
                    vm.CrashTypes.forEach(function (ct) {
                        h += '<tr><td>' + ct.Type + '</td>' +
                             '<td class="pv-prev">' + (ct.CrashesPrev||0) + '</td><td>' + (ct.CrashesCurr||0) + '</td>' +
                             '<td class="pv-prev">' + (ct.FatalPrev||0)   + '</td><td>' + (ct.FatalCurr||0)   + '</td></tr>';
                    });
                    h += '</tbody></table></div>';
                }

                // ── Time slots
                if (vm.TimeSlots && vm.TimeSlots.length > 0) {
                    h += '<div class="pv-section"><div class="pv-section-title">Prevalent times</div>';
                    h += minTable(
                        vm.TimeSlots.map(function (t) { return [t.Slot, t.CrashesPrev, t.CrashesCurr]; }),
                        py, cy) + '</div>';
                }

                // ── Days of week
                var dow = (vm.DaysOfWeek || {}).Provincial || [];
                if (dow.length > 0) {
                    h += '<div class="pv-section"><div class="pv-section-title">Days of the week</div>';
                    h += minTable(
                        dow.map(function (d) { return [d.Day, d.CrashesPrev, d.CrashesCurr]; }),
                        py, cy) + '</div>';
                }

                // ── Summary
                h += '<div class="pv-section"><div class="pv-section-title">Summary</div>';
                h += '<div class="pv-summary">';
                [["Crashes",    pr.Crashes,    c.Crashes   ],
                 ["Fatalities", pr.Fatalities, c.Fatalities],
                 ["Serious",    pr.Serious,    c.Serious   ],
                 ["Slight",     pr.Slight,     c.Slight    ]].forEach(function (r) {
                    var vr  = variance(r[1], r[2]);
                    var cls = parseFloat(vr) > 0 ? "pv-up" : (parseFloat(vr) < 0 ? "pv-down" : "pv-flat");
                    var arrow = parseFloat(vr) > 0 ? "▲" : "▼";
                    h += '<div class="pv-summary-row">' +
                         '<span class="pv-summary-key">' + r[0] + '</span>' +
                         '<span class="pv-summary-val">' + (r[2]||0) + '</span>' +
                         '<span style="color:#ccc;font-size:.72rem;">vs ' + (r[1]||0) + ' prior</span>' +
                         '<span class="pv-tile-var ' + cls + '" style="margin-left:auto;">' + arrow + ' ' + vr + '</span>' +
                         '</div>';
                });
                h += '</div></div>';

                $("#previewArea").html(h);
            }

            // ── Minimal table helper ──────────────────────────────────
            function minTable(rows, py, cy) {
                var h = '<table class="pv-table"><thead><tr>' +
                        '<th></th><th>' + py + '</th><th>' + cy + '</th><th>Var</th>' +
                        '</tr></thead><tbody>';
                rows.forEach(function (r) {
                    var vr  = variance(r[1], r[2]);
                    var cls = parseFloat(vr) > 0 ? "pv-up" : (parseFloat(vr) < 0 ? "pv-down" : "pv-flat");
                    var arrow = parseFloat(vr) > 0 ? "▲" : (parseFloat(vr) < 0 ? "▼" : "–");
                    h += '<tr>' +
                         '<td>' + r[0] + '</td>' +
                         '<td class="pv-prev">' + (r[1]||0) + '</td>' +
                         '<td>' + (r[2]||0) + '</td>' +
                         '<td class="pv-var ' + cls + '">' + arrow + ' ' + vr + '</td>' +
                         '</tr>';
                });
                return h + '</tbody></table>';
            }

            function variance(prev, curr) {
                prev = prev || 0; curr = curr || 0;
                if (prev === 0) return curr === 0 ? "0%" : "N/A";
                var v = ((curr - prev) / prev * 100).toFixed(1);
                return (curr >= prev ? "+" : "") + v + "%";
            }

            // ── Loading helpers ───────────────────────────────────────
            function showLoading(msg) {
                $("#loadingText").text(msg || "Loading…");
                $("#loadingOverlay").addClass("show");
            }
            function hideLoading() {
                $("#loadingOverlay").removeClass("show");
            }

            // Auto-preview on load
            runPreview();
        });
    </script>
}
