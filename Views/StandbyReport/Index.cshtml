@model CrashReport.ViewModels.StandbyReportRequest
@{
    ViewData["Title"] = "Weekly Standby Report";
}

<style>
    
    .sr-page {
        max-width: 620px;
        padding-bottom: 40px;
    }

  
    .sr-page-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
    }

    .sr-page-icon {
        width: 44px;
        height: 44px;
        background: var(--green-mid);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(27,94,32,.25);
    }

    .sr-page-header h4 {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--green-dark);
        margin-bottom: 2px;
    }

    .sr-page-header p {
        font-size: .8rem;
        color: #666;
        margin: 0;
    }

 
    .sr-card {
        background: #fff;
        border: 1px solid #dde8dd;
        border-radius: 10px;
        margin-bottom: 16px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
        transition: box-shadow .2s;
    }

        .sr-card:focus-within {
            box-shadow: 0 2px 12px rgba(46,125,50,.15);
            border-color: var(--green-border);
        }

    .sr-card-header {
        padding: 11px 18px;
        background: var(--green-light);
        border-bottom: 1px solid #c8e6c9;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .sr-card-header-icon {
        font-size: .95rem;
        opacity: .8;
    }

    .sr-card-header-text {
        font-size: .82rem;
        font-weight: 700;
        color: var(--green-dark);
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .sr-card-header-badge {
        margin-left: auto;
        font-size: .7rem;
        color: #888;
        font-weight: 400;
        text-transform: none;
        letter-spacing: 0;
    }

    .sr-card-body {
        padding: 18px 18px 20px;
    }

   
    .sr-date-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: end;
        gap: 0;
    }

    .sr-date-sep {
        text-align: center;
        color: #aaa;
        font-size: .8rem;
        padding: 0 10px 9px;
        white-space: nowrap;
    }

   
    .sr-label {
        display: block;
        font-size: .74rem;
        font-weight: 600;
        color: #555;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: 5px;
    }

   
    .sr-input {
        width: 100%;
        height: 38px;
        padding: 0 11px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: .86rem;
        color: #222;
        background: #fafafa;
        outline: none;
        transition: border-color .15s, box-shadow .15s;
        font-family: "Segoe UI", sans-serif;
    }

        .sr-input:focus {
            border-color: var(--green-mid);
            box-shadow: 0 0 0 3px rgba(46,125,50,.12);
            background: #fff;
        }

        .sr-input:disabled {
            background: #f3f3f3;
            color: #999;
            cursor: not-allowed;
        }

 
    .sr-toggle-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
    }
  

    .sr-toggle-wrap {
        position: relative;
        width: 36px;
        height: 20px;
        flex-shrink: 0;
    }

        .sr-toggle-wrap input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute;
        }

    .sr-toggle-track {
        position: absolute;
        inset: 0;
        background: #ccc;
        border-radius: 20px;
        cursor: pointer;
        transition: background .2s;
    }

    .sr-toggle-wrap input:checked + .sr-toggle-track {
        background: var(--green-mid);
    }

    .sr-toggle-track::after {
        content: '';
        position: absolute;
        top: 3px;
        left: 3px;
        width: 14px;
        height: 14px;
        background: #fff;
        border-radius: 50%;
        transition: transform .2s;
        box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }

    .sr-toggle-wrap input:checked + .sr-toggle-track::after {
        transform: translateX(16px);
    }

    .sr-toggle-label {
        font-size: .83rem;
        color: #444;
        cursor: pointer;
        user-select: none;
    }

  
    .sr-submit-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 24px;
    }

    .sr-btn-generate {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 28px;
        height: 42px;
        background: var(--green-mid);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .88rem;
        font-weight: 600;
        cursor: pointer;
        font-family: "Segoe UI", sans-serif;
        transition: background .15s, box-shadow .15s, transform .1s;
        box-shadow: 0 2px 8px rgba(46,125,50,.3);
    }

        .sr-btn-generate:hover {
            background: var(--green-accent);
            box-shadow: 0 4px 14px rgba(46,125,50,.35);
        }

        .sr-btn-generate:active {
            transform: translateY(1px);
        }

        .sr-btn-generate svg {
            width: 16px;
            height: 16px;
        }

    
    .sr-hint {
        font-size: .75rem;
        color: #888;
        margin-top: 10px;
    }

 
    .sr-quickpick {
        display: flex;
        gap: 6px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .sr-qp-btn {
        font-size: .74rem;
        padding: 4px 10px;
        border: 1px solid #c8e6c9;
        border-radius: 20px;
        background: var(--green-light);
        color: var(--green-dark);
        cursor: pointer;
        transition: background .15s, border-color .15s;
        font-family: "Segoe UI", sans-serif;
    }

        .sr-qp-btn:hover {
            background: #c8e6c9;
            border-color: var(--green-mid);
        }

        .sr-qp-btn.active {
            background: var(--green-mid);
            border-color: var(--green-mid);
            color: #fff;
        }
</style>

<div class="sr-page">


    <div class="sr-page-header">
        <div class="sr-page-icon">📋</div>
        <div>
            <h4>Weekly Standby Report</h4>
            <p>Generate the PATRICIA-format weekly statistics document</p>
        </div>
    </div>

    <form method="post" action="/StandbyReport/Preview" id="srForm">
        @Html.AntiForgeryToken()


        <div class="sr-card">
            <div class="sr-card-header">
                <span class="sr-card-header-icon">📅</span>
                <span class="sr-card-header-text">Report Period</span>
            </div>
            <div class="sr-card-body">


                <div class="sr-quickpick" id="quickpick">
                    <button type="button" class="sr-qp-btn" data-offset="0">This week</button>
                    <button type="button" class="sr-qp-btn" data-offset="-1">Last week</button>
                    <button type="button" class="sr-qp-btn" data-offset="-2">2 weeks ago</button>
                    <button type="button" class="sr-qp-btn" data-offset="-3">3 weeks ago</button>
                </div>

                <div class="sr-date-row">
                    <div>
                        <label class="sr-label" for="DateFrom">From</label>
                        <input id="DateFrom" type="date" name="DateFrom" class="sr-input"
                               value="@Model.DateFrom.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="sr-date-sep">→</div>
                    <div>
                        <label class="sr-label" for="DateTo">To</label>
                        <input id="DateTo" type="date" name="DateTo" class="sr-input"
                               value="@Model.DateTo.ToString("yyyy-MM-dd")" required />
                    </div>
                </div>

            </div>
        </div>


        <div class="sr-card">
            <div class="sr-card-header">
                <span class="sr-card-header-icon">📈</span>
                <span class="sr-card-header-text">Year-on-Year Comparison</span>
                <span class="sr-card-header-badge">optional</span>
            </div>
            <div class="sr-card-body">

                <div class="sr-toggle-row">
                    <label class="sr-toggle-wrap">
                        <input type="checkbox" id="priorToggle" checked />
                        <span class="sr-toggle-track"></span>
                    </label>
                    <span class="sr-toggle-label" onclick="document.getElementById('priorToggle').click()">
                        Include prior year comparison
                    </span>
                </div>

                <div id="priorFields">
                    <div class="sr-date-row">
                        <div>
                            <label class="sr-label" for="PriorYearFrom">Prior From</label>
                            <input id="PriorYearFrom" type="date" name="PriorYearFrom" class="sr-input"
                                   value="@Model.PriorYearFrom?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="sr-date-sep">→</div>
                        <div>
                            <label class="sr-label" for="PriorYearTo">Prior To</label>
                            <input id="PriorYearTo" type="date" name="PriorYearTo" class="sr-input"
                                   value="@Model.PriorYearTo?.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <p class="sr-hint">Defaults to the same week one year ago. Adjust if the calendar split differs.</p>
                </div>

            </div>
        </div>


        <div class="sr-submit-row">
            <button type="submit" class="sr-btn-generate">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                </svg>
                Generate Report
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        (function () {
            const fromInput  = document.getElementById('DateFrom');
            const toInput    = document.getElementById('DateTo');
            const pFromInput = document.getElementById('PriorYearFrom');
            const pToInput   = document.getElementById('PriorYearTo');
            const toggle     = document.getElementById('priorToggle');
            const priorFields= document.getElementById('priorFields');

            
            function syncToggle() {
                const on = toggle.checked;
                priorFields.style.display  = on ? '' : 'none';
                pFromInput.disabled = !on;
                pToInput.disabled   = !on;
                if (!on) { pFromInput.value = ''; pToInput.value = ''; }
            }
            toggle.addEventListener('change', syncToggle);
            syncToggle();

          
            function shiftYear(val, delta) {
                if (!val) return '';
                const d = new Date(val);
                d.setFullYear(d.getFullYear() + delta);
                return d.toISOString().slice(0, 10);
            }
            fromInput.addEventListener('change', () => {
                if (toggle.checked) pFromInput.value = shiftYear(fromInput.value, -1);
            });
            toInput.addEventListener('change', () => {
                if (toggle.checked) pToInput.value = shiftYear(toInput.value, -1);
            });

           
            function getMondayOf(offset) {
                const today = new Date();
                const dow   = today.getDay() || 7; 
                const mon   = new Date(today);
                mon.setDate(today.getDate() - (dow - 1) + offset * 7);
                mon.setHours(0, 0, 0, 0);
                const sun = new Date(mon);
                sun.setDate(mon.getDate() + 6);
                return { mon, sun };
            }
            function fmt(d) { return d.toISOString().slice(0, 10); }

            document.querySelectorAll('.sr-qp-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const offset  = parseInt(btn.dataset.offset, 10);
                    const { mon, sun } = getMondayOf(offset);
                    fromInput.value  = fmt(mon);
                    toInput.value    = fmt(sun);
                    if (toggle.checked) {
                        pFromInput.value = fmt(new Date(mon.setFullYear(mon.getFullYear() - 1)));
                        pToInput.value   = fmt(new Date(sun.setFullYear(sun.getFullYear() - 1)));
                    }
                  
                    document.querySelectorAll('.sr-qp-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                });
            });

            
            const currentFrom = fromInput.value;
            document.querySelectorAll('.sr-qp-btn').forEach(btn => {
                const { mon } = getMondayOf(parseInt(btn.dataset.offset, 10));
                if (fmt(mon) === currentFrom) btn.classList.add('active');
            });
        })();
    </script>
}
