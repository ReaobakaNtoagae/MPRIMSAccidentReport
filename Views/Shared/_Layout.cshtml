<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SA Crash Reporting</title>
    <link rel="stylesheet" href="https://cdn3.devexpress.com/jslib/25.2.7/css/dx.light.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --green-dark: #1b5e20;
            --green-mid: #2e7d32;
            --green-accent: #43a047;
            --green-light: #e8f5e9;
            --green-border: #a5d6a7;
        }

        body {
            font-family: "Segoe UI", sans-serif;
            display: flex;
            height: 100vh;
            overflow: hidden;
            background: #f1f8f1;
        }

        .app-sidebar {
            width: 230px;
            min-width: 230px;
            background: var(--green-dark);
            display: flex;
            flex-direction: column;
            box-shadow: 3px 0 10px rgba(0,0,0,.2);
            overflow-y: auto;
        }

        .app-brand {
            padding: 20px 18px;
            background: var(--green-mid);
            color: #fff;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: .2px;
            border-bottom: 1px solid rgba(255,255,255,.15);
        }

            .app-brand small {
                display: block;
                color: rgba(255,255,255,.55);
                font-size: .72rem;
                font-weight: 400;
                margin-top: 3px;
            }

        .nav-section {
            padding: 16px 18px 5px;
            color: rgba(255,255,255,.3);
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 18px;
            color: rgba(255,255,255,.72);
            text-decoration: none;
            font-size: .86rem;
            transition: all .15s;
            border-left: 3px solid transparent;
        }

            .nav-item a:hover, .nav-item a.active {
                background: rgba(255,255,255,.1);
                color: #fff;
                border-left: 3px solid var(--green-accent);
                padding-left: 15px;
            }

            .nav-item a .nav-icon {
                font-size: 1rem;
                opacity: .75;
            }

        .app-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .app-topbar {
            background: #fff;
            padding: 0 24px;
            border-bottom: 2px solid var(--green-border);
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

            .app-topbar h5 {
                font-size: .95rem;
                font-weight: 600;
                color: var(--green-dark);
            }

        .app-content {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
        }

        .dx-button-mode-contained.dx-button-default {
            background-color: var(--green-mid) !important;
            border-color: var(--green-mid) !important;
        }

            .dx-button-mode-contained.dx-button-default:hover {
                background-color: var(--green-accent) !important;
                border-color: var(--green-accent) !important;
            }

        .dx-tabs-wrapper .dx-tab.dx-tab-selected {
            border-bottom-color: var(--green-mid) !important;
            color: var(--green-mid) !important;
        }

        .dx-datagrid-header-panel, .dx-datagrid .dx-row.dx-header-row > td {
            background: var(--green-light) !important;
            color: var(--green-dark) !important;
        }
    </style>
</head>
<body>
    <aside class="app-sidebar">
        <div class="app-brand">CR1 System<small>SA Road Crash Reporting</small></div>
        <nav>
            <div class="nav-section">Main</div>
            <div class="nav-item"><a asp-controller="Home" asp-action="Index"><span class="nav-icon">⬛</span> Dashboard</a></div>
            <div class="nav-item"><a asp-controller="Home" asp-action="Create"><span class="nav-icon">＋</span> New CR1 Report</a></div>
            <div class="nav-item"><a asp-controller="Import" asp-action="Index"><span class="nav-icon">📥</span> Import Excel</a></div>

            <div class="nav-section">Reports</div>
            <div class="nav-item"><a asp-controller="StandbyReport" asp-action="Index"><span class="nav-icon">📋</span> Weekly Standby</a></div>
            <div class="nav-item"><a asp-controller="Report" asp-action="Index"><span class="nav-icon">📊</span> Monthly Report</a></div>

            <div class="nav-section">Records</div>
            <div class="nav-item"><a asp-controller="Crashes" asp-action="Index"><span class="nav-icon">△</span> Crash Reports</a></div>
            <div class="nav-item"><a asp-controller="Persons" asp-action="Index"><span class="nav-icon">●</span> Persons</a></div>
            <div class="nav-item"><a asp-controller="Vehicles" asp-action="Index"><span class="nav-icon">⬛</span> Vehicles</a></div>

            <div class="nav-section">Admin</div>
            <div class="nav-item"><a asp-controller="Lookups" asp-action="Index"><span class="nav-icon">🗂</span> Manage Lookups</a></div>
        </nav>
    </aside>
    <div class="app-main">
        <div class="app-topbar"><h5>@(ViewData["Title"] ?? "Dashboard")</h5></div>
        <div class="app-content">@RenderBody()</div>
    </div>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn3.devexpress.com/jslib/25.2.7/js/dx.all.js"></script>
    <script src="~/js/lookup-autocomplete.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
